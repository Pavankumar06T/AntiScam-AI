# --- Required -----------------------------------------------------------------
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# --- Model --------------------------------------------------------------------
# Groq rotates its catalogue. If this model is retired, the app resolves against
# the live model list at startup and falls back automatically (see app/config.py).
MODEL_NAME=llama-3.3-70b-versatile
TEMPERATURE=0.2
GROQ_TIMEOUT_SECONDS=30

# --- Risk thresholds ----------------------------------------------------------
# Single source of truth for "what counts as a warning", shared by the API,
# the orchestrator, and the dashboard.
WARN_THRESHOLD=50
URGENT_THRESHOLD=75

# Weight of the deterministic rule layer when fused with the LLM score (0.0-1.0).
# The LLM is the primary judge; rules are a minority vote that anchors hard signals.
RULE_WEIGHT=0.25

# --- Server -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
